1772643123591898	bones-dev	itc:v3:AWKSZJkkk5JkmZMxAAAAQatWqrq1bWwAAAE3oAs		item.create	bn-1k7b	{"description":"Projection rebuild fails after month rotation: forwarding pointer (14 bytes) in sealed shard 2026-02.events but manifest claims 1192415 bytes; subsequent reads fail with parse error","kind":"task","title":"Projection rebuild fails after month rotation: forwarding pointer (14 bytes) in sealed shard 2026-02.events but manifest claims 1192415 bytes; subsequent reads fail with parse error"}	blake3:2rfBo0qm5mhQ2R4cdmpzEGSgXaJN8B3BLue59aa7o6Q
